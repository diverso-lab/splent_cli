#
# Generates and applies initial migrations for all features that ship a
# migrations/ directory. Features with no schema changes are skipped
# automatically by Alembic (no new file is created).
#
# This script is idempotent: safe to run on every startup.

set -e

echo "🚀 [Initialize migrations] entrypoint starting..."

splent db:migrate

echo "✅ [Initialize migrations] entrypoint finished."
