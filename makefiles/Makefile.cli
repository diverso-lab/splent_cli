.PHONY: cli preflight

# Host-side pre-flight only: Docker installed/running, Compose v2, gitconfig/ssh
# sanity. Does not touch the container.
preflight: ## Run host pre-flight checks only (no container)
	@bash scripts/preflight_cli.sh

cli: ## Enter the CLI container (full pre-flight; day-to-day shortcut)
	@bash scripts/preflight_cli.sh splent_cli_container
	@$(MAKE) enter
