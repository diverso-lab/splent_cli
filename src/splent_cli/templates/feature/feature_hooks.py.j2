from splent_framework.hooks.template_hooks import register_template_hook
from flask import url_for


# ── Script hooks ─────────────────────────────────────────────────────────────
# Register the feature's compiled bundle so it loads on every page
# via the layout.scripts hook in the product's base_template.html.

def {{ short_name }}_scripts():
    return (
        '<script src="'
        + url_for(
            "{{ short_name }}.assets",
            subfolder="dist",
            filename="{{ feature_name }}.bundle.js",
        )
        + '"></script>'
    )


register_template_hook("layout.scripts", {{ short_name }}_scripts)
