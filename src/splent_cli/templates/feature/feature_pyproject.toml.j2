[build-system]
requires = ["setuptools>=80.3.1", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "splent_feature_{{ feature_name }}"
version = "0.0.1"
readme = "README.md"
requires-python = ">=3.13"

dependencies = [

]

[tool.setuptools]
package-dir = { "" = "src" }
include-package-data = true

[tool.setuptools.packages.find]
where = ["src"]

[tool.splent]
cli_version = "{{ cli_version }}"

# ── Feature Contract ──────────────────────────────────────────────────────────
# Declares what this feature provides to and requires from the product.
# Used by `splent feature:check` and `splent product:derive` for validation.
[tool.splent.contract]
description = "{{ feature_name }} feature"

[tool.splent.contract.provides]
# Routes exposed by this feature
routes = ["/{{ feature_name }}"]
# Blueprint names registered into Flask
blueprints = ["{{ feature_name }}_bp"]
# SQLAlchemy models introduced by this feature
models = []
# CLI commands added by this feature
commands = []

[tool.splent.contract.requires]
# Other SPLENT features this feature depends on (e.g. ["auth", "mail"])
features = []
# Environment variables this feature expects to be set
env_vars = []
