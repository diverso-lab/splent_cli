[build-system]
requires = ["setuptools>=80.3.1", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ product_name }}"
version = "0.0.1"
description = "{{ product_name }} is an app built with SPLENT (https://www.splent.io)"
readme = "README.md"
requires-python = ">=3.13"

dependencies = [

]

[project.optional-dependencies]
dev = [
    "watchdog"
]

core = [
    "splent_framework"
]

[tool.splent]
cli_version = "{{ cli_version }}"

# Features active in all environments
features = []

# Features active only in dev (e.g. debug tools, fake data generators)
features_dev = []

# Features active only in prod (e.g. monitoring, caching)
features_prod = []

# Layout hooks declared in base_template.html.
# Features register callbacks to these hooks via register_template_hook().
[tool.splent.layout]
base_template = "base_template.html"
hooks = [
    "layout.head.css",
    "layout.anonymous_sidebar",
    "layout.authenticated_sidebar",
    "layout.sidebar.authenticated.items",
    "layout.navbar.anonymous",
    "layout.navbar.authenticated",
    "layout.footer",
    "layout.scripts",
]

[tool.splent.uvl]
mirror = "uvlhub.io"
doi = "10.5281/zenodo.19219696"
file = "{{ product_name }}.uvl"

[tool.setuptools]
package-dir = { "" = "src" }

[tool.setuptools.packages.find]
where = ["src"]
