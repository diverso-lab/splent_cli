#!/bin/bash

# ---------------------------------------------------------------------------
# Creative Commons CC BY 4.0 - SPLENT - Diverso Lab
# ---------------------------------------------------------------------------
# This script installs all editable features listed in the product's
# pyproject.toml under [project.optional-dependencies.features].
# ---------------------------------------------------------------------------

set -e

echo "🚀 [Install features] entrypoint starting..."
echo "📦 Installing editable features listed in [features] of pyproject.toml..."

features=$(python3 -c '
import os, tomllib
with open("/workspace/{{ product_name }}/pyproject.toml", "rb") as f:
    data = tomllib.load(f)
splent = data.get("tool", {}).get("splent", {})
feats = list(splent.get("features", []))
env = os.getenv("SPLENT_ENV")
if env:
    feats += [f for f in splent.get(f"features_{env}", []) if f not in feats]
if not feats:
    feats = data.get("project", {}).get("optional-dependencies", {}).get("features", [])
print("\n".join(feats))
')

echo "📃 Features parsed:"
echo "$features"

for feature in $features; do
    # Parse "splent-io/splent_feature_auth@v1.2.1" → name_ver="splent_feature_auth@v1.2.1"
    if echo "$feature" | grep -q '/'; then
        name_ver="${feature#*/}"
    else
        name_ver="$feature"
    fi

    found_path=""
    for org_dir in /workspace/{{ product_name }}/features/*; do
        [ -d "$org_dir" ] || continue
        candidate="$org_dir/$name_ver"
        if [ -d "$candidate" ]; then
            found_path="$candidate"
            break
        fi
    done

    if [ -n "$found_path" ]; then
        # Resolve the real path of the symlink for comparison
        real_path=$(cd "$found_path" 2>/dev/null && pwd -P) || real_path=""
        current_path=$(pip show "${name_ver%%@*}" 2>/dev/null | grep "Editable project location" | cut -d' ' -f4-)
        current_real=$(cd "$current_path" 2>/dev/null && pwd -P) || current_real=""

        if [ -n "$current_real" ] && [ "$current_real" = "$real_path" ]; then
            echo "✅ $feature already installed."
        else
            echo "🔁 Installing $feature in editable mode from $found_path..."
            if pip install --no-cache-dir --root-user-action=ignore -e "$found_path"; then
                # Advance lifecycle state to "installed"
                python3 -c "
from splent_cli.utils.lifecycle import advance_state, resolve_feature_key_from_entry
import os
key, ns, name, ver = resolve_feature_key_from_entry('$feature')
product_path = os.path.join(os.getenv('WORKING_DIR', '/workspace'), os.getenv('SPLENT_APP', ''))
advance_state(product_path, os.getenv('SPLENT_APP', ''), key, to='installed', namespace=ns, name=name, version=ver)
" 2>/dev/null || true
            else
                echo "❌ Error installing $feature"
            fi
        fi
    else
        echo "⚠️  $feature not found locally under /workspace/{{ product_name }}/features/*/. Skipping."
    fi
done

echo "✅ [Install features] entrypoint finished."
