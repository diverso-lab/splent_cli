.PHONY: cli

cli:
	@echo "🚀 Entering SPLENT CLI shell with .env loaded..."
	@docker exec -u splent -it splent_cli_container bash -lc '\
		unset SPLENT_APP; \
		export HOME=/home/splent; \
		if [ -f /workspace/.env ]; then \
			echo "📦 Loading environment variables from .env..."; \
			set -a; \
			. /workspace/.env; \
			set +a; \
			echo "✅ Environment loaded:"; \
			env | grep -E "^SPLENT_" || true; \
		else \
			echo "⚠️  No .env file found in /workspace"; \
		fi; \
		exec bash -i'